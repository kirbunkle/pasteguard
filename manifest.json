{
  "name": "pasteguard",
  "version": "0.1",
  "manifest_version": 3,
  "description": "Browser extension to protect against copy-pasting sensitive data into AI chat inputs.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ]
}
